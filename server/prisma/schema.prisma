generator client {
  provider     = "prisma-client"
  output       = "../src/modules/prisma/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// <=== User & Auth Schema ===>

// User Model
model User {
  id         String   @id @default(uuid(4)) @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  display_name String? @db.VarChar(50)
  age          Int?

  email    String @unique @db.VarChar(255)
  password String @db.VarChar(255)

  refreshTokens RefreshToken[]
  userRoles     UserRole[]
  passwordToken PasswordToken?
  createdRoles  Role[] // User Created Roles
  categories    Category[]
  cars          Car[]
  carRents      CarRent[]

  @@map("users")
}

// token for passwords
model PasswordToken {
  id         String   @id @default(uuid(4)) @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  token      String   @db.VarChar(64)
  expires_at DateTime

  user_id String @unique @db.Uuid
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expires_at])
  @@map("password_tokens")
}

// RefreshToken Model
model RefreshToken {
  id         String   @id @default(uuid(4)) @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  expires_at DateTime
  revoked_at DateTime?
  token      String    @unique @db.VarChar(64)
  remember   Boolean   @default(false) @db.Boolean

  user_id String @db.Uuid
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_tokens")
}

// <=== Permissions & Roles Schema ===>

// Permisisons Model
model Permission {
  id         String   @id @default(uuid(4)) @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  name        String  @unique @db.VarChar(100)
  description String? @db.VarChar(500)

  rolePermissions RolePermission[]

  @@map("permissions")
}

// Role Model
model Role {
  id         String   @id @default(uuid(4)) @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  name        String  @unique @db.VarChar(100)
  description String? @db.VarChar(500)

  creator_id String? @db.Uuid
  creator    User?   @relation(fields: [creator_id], references: [id], onDelete: SetNull)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

// relation for Permissions and Roles
model RolePermission {
  id         String   @id @default(uuid(4)) @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  permission_id String     @db.Uuid
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  role_id String @db.Uuid
  role    Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([role_id, permission_id])
  @@index([permission_id])
  @@index([role_id])
  @@map("role_permission")
}

// relation for user to role (many to many)
model UserRole {
  id         String   @id @default(uuid(4)) @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user_id String @db.Uuid
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  role_id String @db.Uuid
  role    Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([role_id, user_id])
  @@index([role_id])
  @@index([user_id])
  @@map("user_roles")
}

// Category Model
model Category {
  id         String   @id @default(uuid(4)) @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  name        String  @db.VarChar(100)
  slug        String  @unique @db.VarChar(150)
  description String? @db.VarChar(500)

  creator_id String? @db.Uuid
  creator    User?   @relation(fields: [creator_id], references: [id], onDelete: SetNull)

  cars Car[]

  @@map("categories")
}

// Car Model
model Car {
  id         String   @id @default(uuid(4)) @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  name          String  @db.VarChar(100)
  slug          String  @unique @db.VarChar(150)
  company       String  @db.VarChar(100)
  price_at_hour Int     @db.Integer
  image         String? @db.VarChar(500)

  tags        String[] @db.VarChar(50)
  description String?  @db.VarChar(500)

  in_rent  Boolean @default(false) @db.Boolean
  can_rent Boolean @default(true) @db.Boolean

  category_id String   @db.Uuid
  category    Category @relation(fields: [category_id], references: [id])

  creator_id String? @db.Uuid
  creator    User?   @relation(fields: [creator_id], references: [id], onDelete: SetNull)

  activeRent CarRent? @relation("activeRent")

  @@index([category_id])
  @@map("cars")
}

model CarRent {
  id         String   @id @default(uuid(4)) @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  description String? @db.VarChar(500)

  price      Int      @db.Integer
  started_at DateTime @default(now())
  end_at     DateTime

  user_id String @db.Uuid
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  car_id String @unique @db.Uuid
  car    Car    @relation("activeRent", fields: [car_id], references: [id], onDelete: Restrict)

  @@map("car_rents")
}
